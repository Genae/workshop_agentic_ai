root = true

[*]
indent_style = space
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.cs]
indent_size = 4
dotnet_sort_system_directives_first = true
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_space_after_cast = false
csharp_preserve_single_line_blocks = true

# Dead-code guardrail — unused private members are build errors
dotnet_diagnostic.IDE0051.severity = warning
dotnet_diagnostic.IDE0052.severity = warning

# Suppress CA2007 (ConfigureAwait) — not needed in application code
dotnet_diagnostic.CA2007.severity = none

# Suppress CA1848/CA1873 — LoggerMessage source generators are overkill for a single-shot CLI
dotnet_diagnostic.CA1848.severity = none
dotnet_diagnostic.CA1873.severity = none
