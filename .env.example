# Copy this file to .env and fill in your values. Never commit .env.
ANTHROPIC_API_KEY=your-api-key-here
PAPERCLAW_IMAP_HOST=imap.example.com
PAPERCLAW_IMAP_PORT=993
PAPERCLAW_IMAP_USER=you@example.com
PAPERCLAW_IMAP_PASSWORD=your-password-here
PAPERCLAW_LIBRARY_PATH=/absolute/path/to/library
PAPERCLAW_LOG_LEVEL=Information
